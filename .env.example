# ===========================================
# Claw Command — Environment Variables
# Copy this file to .env.local and fill in your values
# ===========================================

# ---------- Database ----------
DATABASE_URL=
POSTGRES_URL=

# ---------- Auth ----------
AUTH_USER=
AUTH_PASS=
CRON_SECRET=
SEED_SECRET=

# ---------- Next.js / App ----------
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---------- OpenAI ----------
OPENAI_API_KEY=

# ---------- News ----------
NEWS_API_KEY=

# ---------- Google OAuth (Email) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/email/oauth/callback

# ---------- Mission Control ----------
MC_API_KEY=
MOCO_APP_TOKEN=

# ---------- OpenClaw ----------
OPENCLAW_URL=
OPENCLAW_GATEWAY_URL=
OPENCLAW_METRICS_URL=
OPENCLAW_METRICS_TOKEN=
OPENCLAW_WORKSPACE=

# ---------- SAM.gov ----------
SAM_GOV_API_KEY=

# ---------- Token Budget ----------
TOKEN_BUDGET_MONTHLY_USD=300
TOKEN_ALERT_THRESHOLD_PCT=

# ---------- Claude ----------
CLAUDE_PROJECTS_DIR=
